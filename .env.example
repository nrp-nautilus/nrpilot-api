# Environment Configuration

# Set to 'development' or 'dev' for pretty-printed logs
# Set to anything else for JSON output (default for production)
ENV=development

# The logging level (INFO, DEBUG, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Kubernetes API access (read-only service account recommended)
KUBERNETES_HOST=https://kubernetes.default.svc
KUBERNETES_API_KEY=change-me

# NRP LLM gateway (OpenAI-compatible)
NRP_LLM_TOKEN=change-me
NRP_LLM_BASE_URL=https://llm.nrp-nautilus.io/api/v1
MODEL=qwen3-small

## NRP Documentation service (used by documentation tooling)
# Base URL for documentation lookups.
NRP_DOCUMENTATION_URL=https://nrp.ai/documentation/
# Timeout (seconds) for documentation requests.
NRP_DOCUMENTATION_TIMEOUT_SECONDS=10.0
# Maximum number of documentation results to return.
NRP_DOCUMENTATION_MAX_RESULTS=3
